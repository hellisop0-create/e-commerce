rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "vetdrsaad5@gmail.com" ||
        request.auth.token.email == "hellisop0@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'sku', 'name', 'price', 'stock', 'description', 'currency', 'category', 'images', 'metadata']) &&
             data.id is string && data.id.size() <= 128 &&
             data.sku is string && data.sku.size() <= 64 &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.displayName is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'paymentMethod', 'shippingInfo', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 8 &&
             data.userId == request.auth.uid &&
             data.items is list &&
             data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'completed', 'cancelled'] &&
             data.paymentMethod in ['Easypaisa', 'JazzCash', 'COD', 'Wallet'] &&
             data.shippingInfo is map &&
             data.shippingInfo.keys().hasAll(['fullName', 'address', 'city', 'postalCode', 'phone']) &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidUser(incoming());
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
